# ── ENVIRONMENT VARIABLES ──────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the real values.
# Do not commit .env.local to Git.

# The base URL of your website (used for SEO and Sitemap generation)
NEXT_PUBLIC_SITE_URL=https://www.birchandbloom.com

# Email Configuration (For the Contact Form)
# If using Resend (recommended for Next.js):
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=hello@birchandbloom.com

# Analytics (Optional)
# If using Google Analytics:
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Map API Key (Optional - if you add a map later)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_key_here